# Copia este archivo a .env.local para usar Supabase también en desarrollo.
# Si NO defines estas variables, la app usa un archivo JSON local automáticamente
# (perfecto para desarrollo). En Vercel SÍ debes definirlas.

# Project Settings -> API -> Project URL
SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Project Settings -> API -> Project API keys -> service_role (¡SECRETO! solo servidor)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Clave de administrador para subir clases (solo Angel). Cámbiala por una segura.
# Si no la defines, por defecto es "angel-admin".
ADMIN_PASSWORD=angel-admin
